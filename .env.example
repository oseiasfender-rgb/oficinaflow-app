NODE_ENV=development
PORT=3000
APP_VERSION=1000.100.9
DATABASE_URL=postgresql://oficinaos:oficinaos@localhost:5432/oficinaos?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=troque-por-uma-chave-de-acesso-com-no-minimo-32-caracteres
JWT_REFRESH_SECRET=troque-por-uma-chave-de-refresh-com-no-minimo-32-caracteres
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGINS=http://localhost:5173
BOOTSTRAP_ADMIN_EMAIL=admin@oficinaos.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# V1000.50 — Integrações
WEBHOOK_SECRET=change-me
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=OficinaOS <no-reply@oficinaos.local>
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
MERCADOPAGO_ACCESS_TOKEN=
S3_REGION=us-east-1
S3_BUCKET=oficinaos
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123

# V1000.90 — Observabilidade, segurança e deploy
LOG_LEVEL=info
METRICS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
APP_ENVIRONMENT=development
RELEASE_SHA=local
BACKUP_RETENTION_DAYS=30
POSTGRES_BACKUP_DIR=./backups

# Worker / BullMQ / Outbox
WORKER_CONCURRENCY=5
WORKER_HEALTH_PORT=9090
OUTBOX_POLL_MS=5000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10
DELIVERY_MAX_ATTEMPTS=8
SCHEDULER_POLL_MS=30000
WORKER_LOCK_TIMEOUT_MS=120000
AI_ENDPOINT=
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_ALLOWED_MODELS=gpt-4.1-mini
AI_TIMEOUT_MS=30000
AI_TENANT_DAILY_REQUEST_LIMIT=500
AI_USER_DAILY_REQUEST_LIMIT=100
AI_TENANT_DAILY_TOKEN_LIMIT=1000000
AI_STORE_PROMPTS=false
